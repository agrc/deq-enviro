{
  "name": "deq-enviro",
  "version": "2.1.2-rc.2",
  "private": true,
  "description": "DEQ Interactive Map",
  "license": "MIT",
  "author": "UGRC",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "build:cloudrun": "docker build ./cloudrun --target dev -t download",
    "build:dev": "pnpm run build:update-remote-config-defaults && pnpm run build && pnpm run build:storybook",
    "build:prod": "pnpm run build:update-remote-config-defaults && pnpm run build",
    "build:stage": "pnpm run build:update-remote-config-defaults && pnpm run build && pnpm run build:storybook",
    "build:storybook": "storybook build --output-dir ./dist/storybook",
    "build:update-remote-config-defaults": "node build-scripts/updateRemoteConfigDefaults.js",
    "copy:arcgis": "cpy \"./node_modules/@arcgis/core/assets/**\" ./public/assets",
    "dev": "cross-env NODE_ENV=development concurrently 'pnpm run dev:firebase' 'pnpm run dev:vite' 'pnpm run dev:cloudrun'",
    "dev:cloudrun": "docker run -p 5010:5010 --mount type=bind,source=$HOME/.config/gcloud,target=/gcp/config,readonly download",
    "dev:firebase": "export GOOGLE_APPLICATION_CREDENTIALS=\"$PWD/functions/functions-key-dev.json\" && ./scripts/start-emulators.sh",
    "dev:vite": "vite",
    "format": "prettier --write .",
    "postinstall": "pnpm run copy:arcgis",
    "lint": "eslint ./ && tsc",
    "lint:fix": "eslint ./ --quiet --fix",
    "preview": "vite preview",
    "save-firebase-state": "pnpm exec firebase emulators:start --import .emulator-data --export-on-exit --only functions",
    "start": "pnpm run dev",
    "storybook": "storybook dev -p 6006",
    "test": "vitest"
  },
  "browserslist": {
    "production": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "prettier": {
    "plugins": [
      "prettier-plugin-organize-imports",
      "./node_modules/prettier-plugin-jsdoc/dist/index.js",
      "prettier-plugin-packagejson",
      "prettier-plugin-tailwindcss"
    ],
    "semi": true,
    "singleQuote": true
  },
  "overrides": {
    "react-virtual": {
      "react": "$react"
    }
  },
  "dependencies": {
    "@arcgis/core": "^5.0.19",
    "@arcgis/map-components": "^5.0.19",
    "@esri/calcite-components": "^5.1.0",
    "@radix-ui/react-accessible-icon": "^1.1.8",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.100.14",
    "@tanstack/react-table": "^8.21.3",
    "@ugrc/esri-theme-toggle": "^2.0.0",
    "@ugrc/utah-design-system": "^4.0.3",
    "@utahdts/utah-design-system-header": "^5.1.0",
    "@xstate/react": "^6.1.0",
    "clsx": "^2.1.1",
    "downshift": "^9.3.4",
    "firebase": "^12.14.0",
    "googleapis": "^173.0.0",
    "immer": "^11.1.8",
    "ky": "^2.0.2",
    "localforage": "^1.10.0",
    "lodash": "^4.18.1",
    "lodash-es": "^4.18.1",
    "lucide-react": "^1.17.0",
    "react": "^19.2.7",
    "react-aria": "^3.49.0",
    "react-aria-components": "^1.18.0",
    "react-content-loader": "^7.1.2",
    "react-dom": "^19.2.7",
    "react-draggable": "^4.6.0",
    "react-error-boundary": "^6.1.2",
    "react-stately": "^3.47.0",
    "react-virtual": "^2.10.4",
    "tailwind-merge": "^3.6.0",
    "use-immer": "^0.11.0",
    "xstate": "^5.32.0",
    "yup": "^1.7.1"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.2.1",
    "@dotenvx/dotenvx": "^1.71.0",
    "@storybook/addon-docs": "^10.4.2",
    "@storybook/addon-links": "^10.4.2",
    "@storybook/react-vite": "^10.4.2",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/vite": "^4.3.0",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@ugrc/eslint-config": "^1.3.0",
    "@ugrc/tailwind-preset": "^2.0.0",
    "@ugrc/tsconfigs": "^1.0.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^10.0.3",
    "cpy-cli": "^7.0.0",
    "cross-env": "^10.1.0",
    "eslint": "^10.2.0",
    "eslint-plugin-storybook": "10.4.2",
    "firebase-admin": "^13.10.0",
    "firebase-tools": "^15.19.0",
    "happy-dom": "^20.9.0",
    "if-env": "^1.0.4",
    "prettier": "^3.8.3",
    "prettier-plugin-jsdoc": "^1.8.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-packagejson": "^3.0.2",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "prop-types": "^15.8.1",
    "sass": "^1.100.0",
    "storybook": "^10.4.2",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
