{
  "name": "functions",
  "private": true,
  "description": "Cloud Functions for Firebase",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "deploy": "pnpm exec firebase deploy --only functions",
    "dev:firebase": "export GOOGLE_APPLICATION_CREDENTIALS=\"$PWD/functions-key-dev.json\" && pnpm exec firebase emulators:start --only functions",
    "logs": "pnpm exec firebase functions:log",
    "serve": "pnpm exec firebase emulators:start --only functions",
    "shell": "pnpm exec firebase functions:shell",
    "start": "pnpm run shell"
  },
  "dependencies": {
    "@google-cloud/functions-framework": "^5.0.2",
    "@google-cloud/secret-manager": "^6.1.2",
    "firebase-admin": "^13.10.0",
    "firebase-functions": "^7.2.5",
    "googleapis": "^173.0.0",
    "got": "^15.0.5",
    "knex": "^3.2.10",
    "pg": "^8.21.0",
    "yup": "^1.7.1"
  },
  "devDependencies": {
    "firebase-functions-test": "^3.5.0"
  },
  "engines": {
    "node": "22"
  }
}
